    {
      "id": "generate-confirmation-id",
      "name": "Generate Confirmation ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1060,
        760
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const crypto = require('crypto');\nconst input = $input.first().json;\nconst confirmation_id = crypto.randomBytes(8).toString('hex');\n\n// Build details from arg1/arg2 (plain strings, not JSON)\nconst parts = [];\nif (input.arg1) parts.push(`📅 ${input.arg1}`);\nif (input.arg2) parts.push(`⏰ ${input.arg2}`);\nconst details = parts.join('  ') || '';\n\nreturn [{\n  json: {\n    ...input,\n    confirmation_id,\n    details_text: details\n  }\n}];"
      }
    },
