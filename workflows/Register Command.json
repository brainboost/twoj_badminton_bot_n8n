          "jsCode": "const crypto = require('crypto');\nconst input = $input.first().json;\nconst confirmation_id = crypto.randomBytes(8).toString('hex');\n\n// Parse email from arg1 (format: \"email password\" or just email)\nlet email = '';\ntry {\n  const parts = (input.arg1 || '').trim().split(/\\s+/);\n  email = parts[0] || '';\n} catch(e) {\n  email = input.arg1 || '';\n}\n\nreturn [{\n  json: {\n    ...input,\n    confirmation_id,\n    details_text: email   // used to replace {email} placeholder in translation\n  }\n}];"
