        "parameters": {
          "jsCode": "// Parse /register email password from the original text\nconst input = $input.first().json;\nconst argsString = input.arg1.trim();\n\n// Split by whitespace - first part is email, rest is password\nconst parts = argsString.split(/\\s+/);\nconst email = parts[0] || '';\nconsole.log(parts + \"__\" + email + \"__\")\nconst password = input.arg1.trim() || '';\n\n// Validate\nconst isValid = email.length > 0 && password.length > 0 && email.includes('@');\n\nreturn [{\n  json: {\n    ...input,\n    email: email,\n    hash: password,\n    isValid: isValid,\n    errorType: !email ? 'missing_email' : !password ? 'missing_password' : !email.includes('@') ? 'invalid_email' : null\n  }\n}];"
        },
