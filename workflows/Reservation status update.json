      "position": [
        80,
        -192
      ]
    },
    {
      "parameters": {
        "operation": "executeTool",
        "toolName": "=get_club_schedule",
        "toolParameters": "={\"club_id\":\"{{ $json.club_id }}\", \"date\": \"{{ $('Generate Date Range').item.json.date }}\"}"
      },
      "id": "f736eea0-b12f-4f25-b805-cdf353b20096",
      "name": "Get Club Schedule",
      "type": "n8n-nodes-mcp.mcpClient",
      "typeVersion": 1,
      "position": [
        528,
        -272
      ],
      "credentials": {
        "mcpClientApi": {
          "id": "G9CyzT9PT67tg4V7",
          "name": "Twojtenis MCP Client (STDIO)"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Transform schedule API response to database format\n// Input: MCP response with structuredContent containing schedule data\n// Output: Array of records for database insertion\n\nconst mcpResponse = $input.first().json;\n\n// Extract the actual schedule data from the MCP response structure\nlet scheduleData;\nif (mcpResponse.result && mcpResponse.result.structuredContent) {\n  scheduleData = mcpResponse.result.structuredContent.data;\n} else if (mcpResponse.structuredContent) {\n  scheduleData = mcpResponse.structuredContent.data;\n} else if (mcpResponse.data) {\n  scheduleData = mcpResponse.data;\n} else {\n  throw new Error('Could not find schedule data in response');\n}\n\nconst clubId = scheduleData.club_id;\nconst sportId = scheduleData.sport;\nconst date = scheduleData.date;\nconst courts = scheduleData.availability;\nconst records = [];\n\ncourts.forEach(court => {\n  const courtNumber = court.location_name;\n  \n  // Process each time slot\n  court.slots.forEach(slot => {\n    const start = slot.start;\n    const avail = slot.available;\n    //console.log(time);\n    \n    records.push({\n      club_id: clubId,\n      sport_id: sportId,\n      date: date,\n      court_number: courtNumber,\n      time_slot: start,\n      is_available: avail\n    });\n  });\n});\n\nreturn records;"
      },
