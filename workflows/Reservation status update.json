    {
      "parameters": {
        "jsCode": "// Generate 7 dates from tomorrow to tomorrow + 7 days in DD.MM.YYYY format\nconst dates = [];\nconst today = new Date();\n\nfor (let i = 1; i <= 7; i++) {\n  const futureDate = new Date(today);\n  futureDate.setDate(today.getDate() + i);\n  \n  const day = String(futureDate.getDate()).padStart(2, '0');\n  const month = String(futureDate.getMonth() + 1).padStart(2, '0');\n  const year = futureDate.getFullYear();\n  \n  dates.push({\n    club_id: '958662f0-0bd2-4fdc-8bef-bb2d69761adb',\n    date: `${day}.${month}.${year}`,\n    dayOfWeek: futureDate.toLocaleDateString('en-US', { weekday: 'long' })\n  });\n}\n\nreturn dates;"
      },
      "id": "cdbd258e-8dbe-4e87-8f48-2f5de85d42ac",
      "name": "Generate Date Range",
      "type": "n8n-nodes-base.code",
